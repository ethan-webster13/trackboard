# ---------------------------------------------------------------------------
# Firebase configuration
# ---------------------------------------------------------------------------
# 1. Copy this file to ".env.local"  (that file is git-ignored, so your keys
#    never get committed).
# 2. Paste the values from your Firebase project settings (see the Phase 4
#    setup guide / README).
# 3. Restart the dev server (`npm run dev`) — Vite only reads env files at start.
#
# These VITE_ variables are exposed to the browser; that is expected and safe
# for Firebase web config (see src/firebase.js for why).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — a free API key from https://www.themuse.com/developers/api/v2
# raises the job API's rate limit. The app works without it.
VITE_MUSE_API_KEY=
